{
  "manifest_version": 3,
  "name": "YT Shorts Auto-Scroll",
  "version": "1.0.0",
  "description": "Auto-advances YouTube Shorts when they end — even in Picture-in-Picture.",
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YT Shorts Auto-Scroll",
    "default_icon": {
      "16": "images/toolbar-16.png",
      "19": "images/toolbar-19.png",
      "32": "images/toolbar-32.png",
      "38": "images/toolbar-38.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
